<Window x:Class="CarbonTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CarbonTracker"
        mc:Ignorable="d"
        Title="Carbon Footprint Tracker" Height="600" Width="900" MinHeight="500" MinWidth="800"
        Background="#F4F7F6">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1.5*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1.5*"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0"
               Content="Carbon Footprint Tracker"
               FontSize="22"
               FontWeight="Bold"
               Foreground="#1B5E20" 
               Margin="0,0,0,15"/>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="140"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0" Content="Category:" VerticalAlignment="Center" Foreground="#333333"/>
            <ComboBox x:Name="category_box" Grid.Column="1" Height="28" VerticalAlignment="Center" BorderBrush="#81C784"/>

            <Label Grid.Column="3" Content="Amount:" VerticalAlignment="Center" Foreground="#333333"/>
            <TextBox x:Name="amount_box" Grid.Column="4" Height="26" VerticalAlignment="Center" FontSize="16" BorderBrush="#81C784" Background="#FFFFFF"/>

            <Label Grid.Column="6" Content="Factor:" VerticalAlignment="Center" Foreground="#333333"/>
            <TextBlock x:Name="factor_block" Grid.Column="7" VerticalAlignment="Center" FontWeight="Bold" Foreground="#388E3C"/>

            <Button Grid.Column="9" Content="ADD ACTIVITY" Height="30" Click="Button_Click_Add_Activity" 
                    Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Activities" Padding="8" BorderBrush="#81C784" Foreground="#1B5E20" FontWeight="SemiBold">
                <DataGrid x:Name="activities_grid"
                          AutoGenerateColumns="True"
                          ColumnWidth="*"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          RowBackground="#FFFFFF"
                          AlternatingRowBackground="#E8F5E9"
                          BorderThickness="0"
                          FontWeight="Normal"/>
            </GroupBox>

            <StackPanel Grid.Column="2" VerticalAlignment="Top">
                <Button x:Name="test_copy" Content="TEST COPY" Height="35" Margin="0,0,0,10" Click="Button_Click_Test_Copy"
                        Background="#607D8B" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>

                <Button Content="TEST METHOD" Height="35" Margin="0,0,0,10" Click="Button_Click_Test_Method"
                        Background="#607D8B" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>

                <Button Content="TEST PERFORMANCE" Height="35" Margin="0,0,0,10" Click="Button_Click_Test_Large_Data"
                        Background="#607D8B" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>

                <Button Content="DAILY AMOUNT" Height="35" Click="Button_Click"
                        Background="#607D8B" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <Label Grid.Row="3"
               Content="Results from testing:"
               Margin="0,0,228,5" 
               FontWeight="SemiBold"
               Foreground="#1B5E20"/>

        <TextBox x:Name="results_grid"
                 Grid.Row="4"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 IsReadOnly="True" 
                 FontFamily="Consolas"
                 FontSize="14"
                 Background="#1E1E1E" 
                 Foreground="#4CAF50" 
                 BorderThickness="0"
                 Padding="10"/>
    </Grid>
</Window>